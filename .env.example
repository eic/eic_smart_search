APP_ENV=local
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://smartsearch:smartsearch@postgres:5432/smartsearch
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=collaboration_knowledge_chunks
VECTOR_SIZE=384

CORS_ALLOW_ORIGINS=http://localhost:4000,http://127.0.0.1:4000,https://eic.github.io

# Default local CPU embeddings.
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_HTTP_URL=
EMBEDDING_HTTP_MODEL=
EMBEDDING_QUERY_INSTRUCTION=Given a web search query, retrieve relevant passages that answer the query
GENERATION_PROVIDER=extractive
GENERATION_HTTP_URL=
GENERATION_HTTP_MODEL=
MIN_SUPPORT_SCORE=0.16

# OpenAI answer generation (set GENERATION_PROVIDER=openai to enable).
# Embeddings stay on the free local provider configured above.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_GENERATION_MODEL=
OPENAI_REQUEST_TIMEOUT_S=30
OPENAI_MAX_OUTPUT_TOKENS=600
# gpt-5.x / o-series reasoning models reject temperature; leave blank to omit.
OPENAI_TEMPERATURE=
OPENAI_MAX_CONTEXT_CHARS=1800
# Set these to your model's current pricing for spend tracking in /admin/analytics.
# Leave 0 to disable cost tracking. Example for gpt-4.1-mini: 0.40 input, 1.60 output.
OPENAI_INPUT_COST_PER_1M=0
OPENAI_OUTPUT_COST_PER_1M=0

# Cross-encoder reranker. Off by default. When enabled, dramatically improves
# retrieval precision at the cost of latency. On CPU the default model
# (bge-reranker-base, ~278MB) reranks 20 candidates in a few seconds;
# bge-reranker-v2-m3 is higher quality but ~3x slower on CPU.
# RERANK_TIMEOUT_S falls back to the fused ranking if rerank runs over budget.
RERANK_PROVIDER=none
RERANK_MODEL=BAAI/bge-reranker-base
RERANK_CANDIDATES=20
RERANK_SCORE_WEIGHT=0.7
RERANK_MAX_PASSAGE_CHARS=1500
RERANK_TIMEOUT_S=3.0

# Parent-document retrieval for markdown: after retrieval, replace each hit
# with its enclosing heading section (up to MAX_TOKENS) so the LLM sees more
# context. Hits that share the same parent section are de-duplicated.
# Only applied to files whose filetype is in the list below.
PARENT_EXPANSION_ENABLED=false
PARENT_EXPANSION_FILETYPES=md,markdown
PARENT_EXPANSION_HEADING_DEPTH=2
PARENT_EXPANSION_MAX_TOKENS=1200

# Query rewriting: for short queries, generate paraphrases with the mini model
# and retrieve across all variants. Results are cached per-query. Only runs
# when the query is at most TRIGGER_MAX_WORDS long. Falls open on any error.
# Leave QUERY_REWRITE_MODEL empty to reuse OPENAI_GENERATION_MODEL.
QUERY_REWRITE_PROVIDER=none
QUERY_REWRITE_MODEL=
QUERY_REWRITE_MAX_VARIANTS=2
QUERY_REWRITE_TRIGGER_MAX_WORDS=8
QUERY_REWRITE_MAX_OUTPUT_TOKENS=200
QUERY_REWRITE_TIMEOUT_S=15
QUERY_REWRITE_CACHE_SIZE=512

# In-memory shared cache for /query responses. Same question asked by a second
# user within TTL gets the answer for free (no retrieval, no LLM call).
# Invalidated automatically whenever ingest/reindex modifies content.
QUERY_CACHE_ENABLED=true
QUERY_CACHE_MAX_SIZE=500
QUERY_CACHE_TTL_S=3600

EIC_SITE_URL=https://eic.github.io/
EIC_SITE_MAX_PAGES=500
# Comma-separated URL path prefixes to skip during crawling. The defaults skip
# build-artifact trees (XML geometry files, binaries) which would otherwise
# exhaust the crawl budget with no useful content.
EIC_SITE_EXCLUDE_PREFIXES=/epic/artifacts,/epic/build-,/epic/geoviewer,/epic/craterlake_views,/epic-prod/artifacts,/epic-prod/build-,/EDM4eic/

# --- Additional website sources ---------------------------------------------
EICUG_SITE_URL=https://www.eicug.org/
EICUG_SITE_MAX_PAGES=300
EICUG_SITE_EXCLUDE_PREFIXES=

# BNL EPIC wiki (MediaWiki). Skip Special:/Talk:/File:/etc. or you'll drown
# in user pages and diffs.
BNL_WIKI_URL=https://wiki.bnl.gov/EPIC/index.php?title=Main_Page
BNL_WIKI_MAX_PAGES=500
BNL_WIKI_EXCLUDE_PREFIXES=/EPIC/index.php/Special:,/EPIC/index.php/Talk:,/EPIC/index.php/User:,/EPIC/index.php/User_talk:,/EPIC/index.php/File:,/EPIC/index.php/Category:,/EPIC/index.php/Help:,/EPIC/index.php/MediaWiki:,/EPIC/index.php/Template:,/EPIC/index.php/Template_talk:,/EPIC/skins/,/EPIC/resources/,/EPIC/extensions/,/EPIC/load.php,/EPIC/images/

# --- Single GitHub repo (eic.github.io) ------------------------------------
GITHUB_REPO_OWNER=eic
GITHUB_REPO_NAME=eic.github.io
GITHUB_REPO_REF=master
GITHUB_TOKEN=
GITHUB_MAX_FILES=600

# --- Full GitHub org: markdown/rst only, code excluded ----------------------
GITHUB_ORG=eic
GITHUB_ORG_MAX_REPOS=210
GITHUB_ORG_MAX_FILES=1500

# --- Zenodo community -------------------------------------------------------
ZENODO_COMMUNITY=epic
ZENODO_MAX_RECORDS=200
ZENODO_INCLUDE_PDF_TEXT=true
ZENODO_PDF_MAX_BYTES=26214400
ZENODO_PDF_MAX_CHARS=120000

EPIC_INTERNAL_START_URL=https://www.epic-eic.org/index-internal.html
EPIC_INTERNAL_MAX_PAGES=100
# Use one of these when the internal site requires an authenticated browser/session.
EPIC_INTERNAL_COOKIE=
EPIC_INTERNAL_AUTH_HEADER=

REQUEST_TIMEOUT_SECONDS=20
INGEST_USER_AGENT=eic-smart-search/0.1 (+https://eic.github.io/)
